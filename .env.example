# ── Rename these values and save as ".env" ───────────────────────────────────
#
# Required – Get your key from https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here
#
# Optional – tweak as needed
SMTP_TIMEOUT=10
SMTP_FROM_ADDRESS=probe@yourdomain.com
REQUEST_TIMEOUT=15
MAX_SEARCH_RESULTS=10
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=mistralai/devstral-2-123b-instruct-2512
NVIDIA_TEMPERATURE=0.7
NVIDIA_MAX_TOKENS=1024
OUTPUT_CSV=outreach_results.csv
